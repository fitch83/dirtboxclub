rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────
    function isAdmin() {
      return request.auth != null &&
             request.auth.uid == 'YOUR_ADMIN_UID_HERE';
    }

    // ─── PRODUCTS Collection ────────────────────────────────────────
    // Admin only: read, write
    match /products/{document=**} {
      allow read, write: if isAdmin();
    }

    // ─── ORDERS Collection ────────────────────────────────────────
    // Admin only: read, write
    match /orders/{document=**} {
      allow read, write: if isAdmin();
    }

    // ─── APPLICATIONS Collection ────────────────────────────────────
    // Admin only: read, write
    match /applications/{document=**} {
      allow read, write: if isAdmin();
    }

    // ─── MEMBERS Collection ─────────────────────────────────────────
    // Admin only: read, write
    match /members/{document=**} {
      allow read, write: if isAdmin();
    }

    // ─── CUSTOMERS Collection ────────────────────────────────────────
    // Admin: full access
    // Authenticated customer: read/write own document and subcollections
    match /customers/{uid} {
      allow read, write: if isAdmin() || request.auth.uid == uid;
    }
    // Wishlist subcollection: owner can read/write; admin can read
    match /customers/{uid}/wishlist/{item} {
      allow read, write: if isAdmin() || request.auth.uid == uid;
      // Public read for shareable wishlists
      allow read: if true;
    }

    // ─── CAMPAIGNS Collection ────────────────────────────────────────
    // Admin only: read, write
    // Stores email campaign records: date, subject, segment, recipients,
    // successCount, failureCount, status, body
    match /campaigns/{document=**} {
      allow read, write: if isAdmin();
    }

    // ─── SUBSCRIBERS Collection ──────────────────────────────────────
    // Public: write (for newsletter signups)
    // Admin: read (to view subscriber list)
    // Stores: email, name, subscribedAt, source
    match /subscribers/{document=**} {
      allow create: if request.resource.data.email is string &&
                       request.resource.data.email.size() > 0 &&
                       request.resource.data.subscribedAt is string &&
                       request.resource.data.source is string;
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ─── ANNOUNCEMENTS Collection ────────────────────────────────────
    // Admin only: read, write
    match /announcements/{document=**} {
      allow read, write: if isAdmin();
    }

    // ─── DROPS Collection ────────────────────────────────────────────
    // Admin only: read, write
    match /drops/{document=**} {
      allow read, write: if isAdmin();
    }

    // ─── REVIEWS Collection ──────────────────────────────────────────
    // Public: read approved reviews only
    // Authenticated: create new reviews (one per product per user enforced in app)
    // Admin: full access (approve/reject/delete)
    match /reviews/{reviewId} {
      allow read: if resource.data.status == 'approved' || isAdmin() || request.auth.uid == resource.data.customerId;
      allow create: if request.auth != null &&
                       request.resource.data.customerId == request.auth.uid &&
                       request.resource.data.rating is int &&
                       request.resource.data.rating >= 1 &&
                       request.resource.data.rating <= 5 &&
                       request.resource.data.title is string &&
                       request.resource.data.body is string;
      allow update, delete: if isAdmin();
    }

    // ─── REFERRALS Collection ─────────────────────────────────────────
    // Authenticated: create when signing up via referral link
    // Admin: full access; referrer can read own referrals
    match /referrals/{refId} {
      allow read:   if isAdmin() || request.auth.uid == resource.data.referrerId || request.auth.uid == resource.data.refereeId;
      allow create: if request.auth != null && request.resource.data.refereeId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── DISCOUNT CODES Collection ────────────────────────────────────
    // Admin: full access; authenticated users can read active codes (for validation at checkout)
    match /discountCodes/{codeId} {
      allow read:          if isAdmin() || request.auth != null;
      allow write:         if isAdmin();
      allow create:        if request.auth != null && request.resource.data.referral == true && request.resource.data.forUser == request.auth.uid;
    }

    // ─── INVENTORY Collection ─────────────────────────────────────────
    // Public read; Admin write
    match /inventory/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Default Deny ───────────────────────────────────────────────
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
